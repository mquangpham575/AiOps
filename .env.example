# =============================================================
# AIOps Agent Configuration — Distributed Setup (PC + Azure VM)
# Lấy Gemini API key tại: https://aistudio.google.com/app/apikey
# =============================================================

# ── AI Configuration ────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemma-3-1b-it
AGENT_API_KEY=your_secret_agent_key_here
AI_THROTTLE_INTERVAL=3.0

# ── System Configuration ────────────────────────────────────
TARGET_CONTAINER_NAME=target-app

# ── Service URLs ─────────────────────────────────────────────
PROMETHEUS_URL=http://prometheus:9090

# ── Log and Debug ─────────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG_MODE=false

# ── Grafana ──────────────────────────────────────────────────
GRAFANA_ADMIN_PASSWORD=your_grafana_password_here

# ── Grafana Annotations ──────────────────────────────────────
# Get token: Grafana -> Administration -> Service Accounts -> Add token
## Grafana runs on the loadgen/observability VM in the distributed topology.
## Set this to: http://<AZURE_LOADGEN_IP>:3000
GRAFANA_URL=http://127.0.0.1:3000
GRAFANA_TOKEN=

# ── Azure VM ─────────────────────────────────────────────────
## Current topology uses two VMs:
## - AZURE_APP_IP:      public IP of the App VM (target-app)
## - AZURE_LOADGEN_IP:  public IP of the Loadgen/Observability VM (Grafana)
AZURE_APP_IP=your_app_vm_public_ip_here
AZURE_LOADGEN_IP=your_loadgen_vm_public_ip_here

## Legacy (still supported by some scripts as an alias for AZURE_APP_IP)
AZURE_VM_IP=

AZURE_RESOURCE_GROUP=rg-aiops
AZURE_VM_NAME=aiops-vm
AZURE_LOADGEN_VM_NAME=aiops-loadgen-vm
AZURE_SSH_USER=azureuser
AZURE_SSH_KEY_PATH=~/.ssh/aiops_key
REMOTE_PROJECT_DIR=/home/azureuser/DoAn
