# ============================================================
# HƯỚNG DẪN: Copy file này thành .env rồi
# AI Agent Auth (Security)
# This key is required for POST /webhook (must match X-Agent-Key header)
AGENT_API_KEY=your_secret_agent_key_here

# Gemini API setup
#   cp .env.example .env
# Lấy key tại: https://aistudio.google.com/app/apikey
# ============================================================

# ── AI Configuration ────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemma-3-1b-it
AI_THROTTLE_INTERVAL=3.0

# ── System Configuration ────────────────────────────────────
TARGET_CONTAINER_NAME=target-app
DEFAULT_NETWORK_INTERFACE=eth0

# ── Service URLs ─────────────────────────────────────────────
PROMETHEUS_URL=http://prometheus:9090
ALERTMANAGER_URL=http://alertmanager:9093

# ── Alert Thresholds (Optional - override alert rules) ────────
#CPU_THRESHOLD=80
#MEMORY_THRESHOLD=85
#LATENCY_THRESHOLD=1.5
#REQUEST_RATE_THRESHOLD=100
#SYSTEM_LOAD_THRESHOLD=2.0
#CRITICAL_LOAD_THRESHOLD=4.0

# ── Networking & Rate Limiting ───────────────────────────────
DEFAULT_RATE_LIMIT=50/sec
RATE_LIMIT_BURST=200

# ── Log and Debug ─────────────────────────────────────────────
LOG_LEVEL=INFO
DEBUG_MODE=false

# ── Grafana Annotations ──────────────────────────────────────
# Get token: Grafana → Administration → Service Accounts → Add token
GRAFANA_URL=http://grafana:3000
GRAFANA_TOKEN=
