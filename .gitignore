# =============================================================
# .gitignore for AIOps NT531 Project
# =============================================================

# ── Environment & Secrets ────────────────────────────────────
.env
.env.local
.env.*.local
*.key
*.pem
secrets/
credentials/

# ── Docker & Containers ──────────────────────────────────────
# Docker volumes and data
**/data/
**/volumes/
docker-compose.override.yml
.dockerignore

# Docker build cache
.docker/

# ── Python ───────────────────────────────────────────────────
# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
share/python-wheels/
*.egg-info/
.installed.cfg
*.egg
MANIFEST

# PyInstaller
*.manifest
*.spec

# Virtual environments
venv/
env/
ENV/
env.bak/
venv.bak/
.venv/

# Jupyter Notebook
.ipynb_checkpoints
*.ipynb

# pyenv
.python-version

# pipenv
Pipfile.lock

# ── IDE & Editors ────────────────────────────────────────────
# VSCode
.vscode/
*.code-workspace

# PyCharm
.idea/
*.iml
*.ipr
*.iws

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# Emacs
*~
\#*\#
/.emacs.desktop
/.emacs.desktop.lock
*.elc
auto-save-list
tramp
.\#*

# ── Logs & Temporary Files ───────────────────────────────────
# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*

# Runtime data
pids
*.pid
*.seed
*.pid.lock

# Temporary files
tmp/
temp/
*.tmp
*.temp

# ── Monitoring & Metrics Data ────────────────────────────────
# Prometheus data
prometheus_data/
alertmanager_data/

# Grafana data
grafana_data/
grafana.db

# Test results and coverage
htmlcov/
.tox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
*.py,cover
.hypothesis/
.pytest_cache/
cover/

# ── OS Generated Files ───────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
Icon
._*
.DocumentRevisions-V100
.fseventsd
.Spotlight-V100
.TemporaryItems
.Trashes
.VolumeIcon.icns
.com.apple.timemachine.donotpresent
.AppleDB
.AppleDesktop
Network Trash Folder
Temporary Items
.apdisk

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
*.stackdump
[Dd]esktop.ini
$RECYCLE.BIN/
*.cab
*.msi
*.msix
*.msm
*.msp
*.lnk

# Linux
*~
.fuse_hidden*
.directory
.Trash-*
.nfs*

# ── Project Specific Files ───────────────────────────────────
# Test outputs
test_results/
validation_output.txt
benchmark_results/

# Demo results (keep only manually committed ones)
demos/*/results/*.txt
demos/*/results/*.log
demos/combined_results/*.txt

# Generated reports
reports/
*.pdf
*.docx

# Backup files
*.bak
*.backup
*_backup
*_old

# Lock files
*.lock

# Git hook samples
.git/hooks/*.sample

# Node modules (if any)
node_modules/
npm-debug.log
yarn-error.log

# ── AI/ML Specific ───────────────────────────────────────────
# Model files (if large)
*.model
*.pkl
*.h5
*.pb

# Dataset files
datasets/
data/
*.csv
*.json
*.parquet

# ── Monitoring Tools ─────────────────────────────────────────
# Locust generated files
locust_reports/
*.html

# Performance test results
stress_test_results/
load_test_output/

# ── System Files ─────────────────────────────────────────────
# System monitoring files
/proc
/sys
/dev

# Core dumps
core
core.*

# ── Local Agent Tooling ──────────────────────────────────────
# Claude Code / Superpowers skills (local use only)
.superpowers/
.claude/

# Local-generated docs (not meant for repo)
docs/superpowers

# ── Keep These Files ─────────────────────────────────────────
# Force include certain files that might be ignored by patterns above
!.gitkeep
!.env.example
!docker-compose.yml
!*/Dockerfile
!
.terraform/
.terraform.lock.hcl
terraform.tfstate*

config/prometheus/prometheus.yml
